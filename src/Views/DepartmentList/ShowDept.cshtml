@* ShowDept.cshtml@
@* クラスの名前空間を指定する(C#と同じ) *@
@using WebApp_Src.Presentations.ViewModels
@* View が受け取るデータ型（ViewModel）を宣言asp-for はこの型のプロパティと結びつける *@
@model DepartmentListViewModel;
@{
    ViewData["Title"] = "部門一覧";
}
<h2 class="text-center mt-4">@ViewData["Title"]</h2>

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-4 col-sm-6">
            @* 送信先はControllerのConfirm()、POSTは入力値を送信する*@
            <table class="table table-hover" asp-action="ShowDept" asp-controller="DepartmentList" method="get">
            </table>
            <div class="text-center">
                <button type="submit" formaction="@Url.Action("Back", "Home")" formmethod="post"
                        class="btn btn-secondary">戻る</button>
            </div>

        </div>
    </div>
</div>